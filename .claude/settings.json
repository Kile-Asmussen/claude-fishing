{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Edit(CLAUDE.md)",
      "Edit(TODO.md)",
      "Write(TODO.md)",
      "Edit(Cargo.toml)",
      "Edit(.cargo/config.toml)",
      "Edit(build.rs)",
      "Edit(slop/**/*)",
      "Write(slop/**/*)",
      "Edit(src/*)",
      "Write(src/*)",
      "Edit(src/**/*)",
      "Write(src/**/*)",
      "Bash",
      "Glob",
      "Grep",
      "Read",
      "WebFetch",
      "WebSearch",
      "LSP"
    ],
    "deny": [
      "Agent",
      "Write(.claude/*)",
      "Edit(.claude/*)",
      "Write(.claude/**/*)",
      "Edit(.claude/**/*)"
    ],
    "defaultMode": "dontAsk"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
