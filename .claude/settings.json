{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "enabledMcpjsonServers": [
    "grep-glob"
  ],
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "hooks": {
    "ConfigChange": [
      {
        "hooks": [
          {
            "command": "fishing config-change",
            "type": "command"
          }
        ],
        "matcher": "project_settings|local_settings|user_settings"
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "command": "fishing cwd-changed",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "fishing pre-tool-use",
            "type": "command"
          }
        ],
        "matcher": "Bash|Read|WebFetch|Edit|Write"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "fishing rotate-log",
            "type": "command"
          }
        ]
      }
    ]
  },
  "outputStyle": "default",
  "permissions": {
    "allow": [
      "Edit(CLAUDE.md)",
      "Write(README.md)",
      "Edit(README.md)",
      "Edit(TODO.md)",
      "Write(TODO.md)",
      "Edit(Cargo.toml)",
      "Edit(.cargo/config.toml)",
      "Edit(build.rs)",
      "Edit(slop/**/*)",
      "Write(slop/**/*)",
      "Edit(src/**/*)",
      "Write(src/**/*)",
      "Bash",
      "Read",
      "WebFetch",
      "WebSearch",
      "LSP",
      "ToolSearch",
      "mcp__grep-glob__glob",
      "mcp__grep-glob__grep"
    ],
    "defaultMode": "dontAsk",
    "deny": [
      "Agent",
      "Write(.claude/*)",
      "Edit(.claude/*)",
      "Write(.claude/**/*)",
      "Edit(.claude/**/*)"
    ]
  },
  "spinnerTipsEnabled": false
}